<section class="page-banner" aria-label="Page header">
  <div class="page-banner-bg" style="background-image: url('<%= hero.image_url %>');" aria-hidden="true"></div>
  <div class="page-banner-overlay" aria-hidden="true"></div>
  <div class="container page-banner-content">
    <h1 class="page-banner-title"><%= planter.name %> — Rural Growers</h1>
    <p class="page-banner-subtitle">Select a Rural Grower to view their planting progress and updates.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">Rural Growers</span>
      <h2 class="section-title">Assigned to <%= planter.name %></h2>
      <p class="section-desc">These Rural Growers are working with <%= planter.name %>. Click on a grower to see their updates.</p>
    </div>

    <div style="text-align:center;margin-bottom:32px;">
      <a href="/tracking" class="btn btn-secondary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="margin-right:6px;"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to Urban Planters
      </a>
    </div>

    <div class="tracking-search-bar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="grower-search" placeholder="Search rural growers..." aria-label="Search rural growers">
    </div>

    <div class="tracking-grid" id="grower-grid">
      <% if (growers.length > 0) { %>
        <% growers.forEach(function(g) { %>
          <a href="/tracking/growers/<%= g.id %>/updates" class="tracking-card" data-name="<%= g.name.toLowerCase() %>">
            <div class="tracking-card-avatar">
              <img src="<%= g.image_url || '/assets/images/team-member-1.svg' %>" alt="<%= g.name %>" loading="lazy">
            </div>
            <div class="tracking-card-info">
              <h3><%= g.name %></h3>
              <% if (g.location) { %><p class="loc"><%= g.location %></p><% } %>
              <div class="tracking-card-stats">
                <span class="tracking-badge"><%= g.totalUpdates %> Update<%= g.totalUpdates !== 1 ? 's' : '' %></span>
                <% if (g.latestUpdateDate) { %><span class="tracking-badge outline">Latest: <%= g.latestUpdateDate %></span><% } %>
              </div>
            </div>
          </a>
        <% }); %>
      <% } else { %>
        <div class="text-center" style="grid-column:1/-1;padding:60px 0;">
          <p>No rural growers assigned to this planter.</p>
        </div>
      <% } %>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var searchInput = document.getElementById('grower-search');
  var cards = document.querySelectorAll('#grower-grid .tracking-card');

  searchInput.addEventListener('input', function() {
    var val = this.value.toLowerCase().trim();
    cards.forEach(function(card) {
      var name = card.getAttribute('data-name') || '';
      card.style.display = !val || name.includes(val) ? '' : 'none';
    });
  });
});
</script>
