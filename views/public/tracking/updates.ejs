<section class="page-banner" aria-label="Page header">
  <div class="page-banner-bg" style="background-image: url('<%= hero.image_url || '/assets/images/hero-placeholder.svg' %>');" aria-hidden="true"></div>
  <div class="page-banner-overlay" aria-hidden="true"></div>
  <div class="container page-banner-content">
    <h1 class="page-banner-title"><%= grower.name %> — Progress Updates</h1>
    <p class="page-banner-subtitle"><%= grower.location || '' %><%= planter ? ' | Partnered with ' + planter.name : '' %></p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div style="text-align:center;margin-bottom:32px;">
      <a href="/tracking/planters/<%= planter ? planter.id : '' %>/growers" class="btn btn-secondary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="margin-right:6px;"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to Rural Growers
      </a>
    </div>

    <div class="section-header">
      <span class="section-label">Timeline</span>
      <h2 class="section-title">Updates & Progress</h2>
      <p class="section-desc">Tracking the reforestation progress of <%= grower.name %>.</p>
    </div>

    <div class="public-updates-toolbar">
      <div class="tracking-search-bar" style="max-width:400px;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="public-updates-search" placeholder="Search updates..." aria-label="Search updates">
      </div>
      <div class="public-filter-date">
        <input type="date" id="public-date-filter">
      </div>
    </div>

    <div id="public-timeline" class="public-timeline">
      <% if (updates.length > 0) { %>
        <% updates.forEach(function(u) { %>
          <div class="public-timeline-card" data-title="<%= (u.title || '').toLowerCase() %>" data-date="<%= u.update_date %>">
            <div class="public-timeline-marker">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="public-timeline-content">
              <div class="public-timeline-header">
                <span class="public-timeline-date"><%= u.update_date %></span>
                <% if (u.image_count > 0) { %><span class="public-timeline-count"><%= u.image_count %> photo<%= u.image_count > 1 ? 's' : '' %></span><% } %>
              </div>
              <h3><%= u.title %></h3>
              <% if (u.description) { %><p class="public-timeline-desc"><%= u.description %></p><% } %>
              <% if (u.notes) { %><div class="public-timeline-notes"><%= u.notes %></div><% } %>
              <% if (u.images && u.images.length > 0) { %>
                <div class="public-image-grid">
                  <% u.images.forEach(function(img) { %>
                    <div class="public-image-item" onclick="openPublicLightbox('<%= u.id %>', <%= img.id %>)">
                      <img src="<%= img.image_url %>" alt="<%= u.title %>" loading="lazy">
                    </div>
                  <% }); %>
                </div>
              <% } %>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="text-center" style="padding:60px 0;">
          <p>No updates available yet for this Rural Grower.</p>
        </div>
      <% } %>
    </div>
  </div>
</section>

<div id="public-lightbox" class="lightbox-overlay" style="display:none;" role="dialog" aria-modal="true" aria-label="Image preview">
  <button class="lightbox-close" aria-label="Close">&times;</button>
  <button class="lightbox-nav lightbox-prev" id="public-lightbox-prev" aria-label="Previous image" style="display:none;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button class="lightbox-nav lightbox-next" id="public-lightbox-next" aria-label="Next image" style="display:none;">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
  <div class="lightbox-content">
    <img src="" alt="Preview" id="public-lightbox-img">
  </div>
</div>

<script>
var allUpdates = [];
var currentLightboxUpdateId = null;
var currentLightboxImageIndex = 0;
<% if (updates.length > 0) { %>
  allUpdates = <%- JSON.stringify(updates.map(function(u) {
    return { id: u.id, title: u.title, description: u.description, update_date: u.update_date, notes: u.notes, images: u.images || [] };
  })) %>;
<% } %>

function openPublicLightbox(updateId, imageId) {
  var update = null;
  for (var i = 0; i < allUpdates.length; i++) {
    if (String(allUpdates[i].id) === String(updateId)) { update = allUpdates[i]; break; }
  }
  if (!update || !update.images || update.images.length === 0) return;

  currentLightboxUpdateId = update.id;
  var img = null;
  for (var j = 0; j < update.images.length; j++) {
    if (String(update.images[j].id) === String(imageId)) { img = update.images[j]; currentLightboxImageIndex = j; break; }
  }
  if (!img) { img = update.images[0]; currentLightboxImageIndex = 0; }

  document.getElementById('public-lightbox-img').src = img.image_url;
  updatePublicNavButtons();
  document.getElementById('public-lightbox').style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function updatePublicNavButtons() {
  var imgs = getCurrentLightboxImages();
  if (!imgs) { document.getElementById('public-lightbox-prev').style.display = 'none'; document.getElementById('public-lightbox-next').style.display = 'none'; return; }
  document.getElementById('public-lightbox-prev').style.display = currentLightboxImageIndex > 0 ? '' : 'none';
  document.getElementById('public-lightbox-next').style.display = currentLightboxImageIndex < imgs.length - 1 ? '' : 'none';
}

function getCurrentLightboxImages() {
  for (var i = 0; i < allUpdates.length; i++) {
    if (allUpdates[i].id === currentLightboxUpdateId) return allUpdates[i].images || [];
  }
  return null;
}

function navigatePublicLightbox(direction) {
  var imgs = getCurrentLightboxImages();
  if (!imgs || imgs.length === 0) return;
  currentLightboxImageIndex = Math.max(0, Math.min(imgs.length - 1, currentLightboxImageIndex + direction));
  document.getElementById('public-lightbox-img').src = imgs[currentLightboxImageIndex].image_url;
  updatePublicNavButtons();
}

function closePublicLightbox() {
  document.getElementById('public-lightbox').style.display = 'none';
  document.body.style.overflow = '';
}

document.addEventListener('DOMContentLoaded', function() {
  var lb = document.getElementById('public-lightbox');
  lb.addEventListener('click', function(e) { if (e.target === this) closePublicLightbox(); });
  lb.querySelector('.lightbox-close').addEventListener('click', closePublicLightbox);
  document.getElementById('public-lightbox-prev').addEventListener('click', function() { navigatePublicLightbox(-1); });
  document.getElementById('public-lightbox-next').addEventListener('click', function() { navigatePublicLightbox(1); });
  document.addEventListener('keydown', function(e) {
    if (lb.style.display === 'flex' && e.key === 'Escape') closePublicLightbox();
    if (lb.style.display === 'flex' && e.key === 'ArrowLeft') navigatePublicLightbox(-1);
    if (lb.style.display === 'flex' && e.key === 'ArrowRight') navigatePublicLightbox(1);
  });

  var searchInput = document.getElementById('public-updates-search');
  var dateInput = document.getElementById('public-date-filter');
  var cards = document.querySelectorAll('.public-timeline-card');

  function filterCards() {
    var searchVal = (searchInput.value || '').toLowerCase().trim();
    var dateVal = dateInput.value;
    cards.forEach(function(card) {
      var title = card.getAttribute('data-title') || '';
      var date = card.getAttribute('data-date') || '';
      var matchSearch = !searchVal || title.includes(searchVal);
      var matchDate = !dateVal || date === dateVal;
      card.style.display = matchSearch && matchDate ? '' : 'none';
    });
  }

  searchInput.addEventListener('input', filterCards);
  dateInput.addEventListener('change', filterCards);
});
</script>
