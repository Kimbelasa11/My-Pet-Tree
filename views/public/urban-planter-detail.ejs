<section class="page-banner" aria-label="Page header">
  <div class="page-banner-bg" style="background-image: url('<%= hero.image_url %>');" aria-hidden="true"></div>
  <div class="page-banner-overlay" aria-hidden="true"></div>
  <div class="container page-banner-content">
    <h1 class="page-banner-title"><%= hero.title || 'Urban Planter' %></h1>
    <p class="page-banner-subtitle"><%= hero.subtitle || 'Learn more about the inspiring individuals supporting reforestation and creating a greener future through tree sponsorship.' %></p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div style="text-align:center;margin-bottom:32px;">
      <a href="/impact" class="btn btn-outline">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" style="margin-right:6px;vertical-align:middle;"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to Impact
      </a>
    </div>

    <div class="profile-detail">
      <div class="profile-detail-avatar">
        <img src="<%= planter.image_url || '/assets/images/avatar-placeholder.svg' %>" alt="<%= planter.name %>">
      </div>
      <h2 class="profile-detail-name"><%= planter.name %></h2>

      <% if (planter.bio) { %>
        <p class="profile-detail-bio"><%= planter.bio %></p>
      <% } %>

      <div class="profile-attributes">
        <div class="attribute-grid">
          <% if (planter.email) { %>
            <div class="attribute-item">
              <span class="attribute-label">Email</span>
              <span class="attribute-value"><%= planter.email %></span>
            </div>
          <% } %>
          <% if (planter.phone) { %>
            <div class="attribute-item">
              <span class="attribute-label">Phone</span>
              <span class="attribute-value"><%= planter.phone %></span>
            </div>
          <% } %>
          <% if (planter.location) { %>
            <div class="attribute-item">
              <span class="attribute-label">Location</span>
              <span class="attribute-value"><%= planter.location %></span>
            </div>
          <% } %>
          <% if (planter.organization) { %>
            <div class="attribute-item">
              <span class="attribute-label">Organization</span>
              <span class="attribute-value"><%= planter.organization %></span>
            </div>
          <% } %>
        </div>
      </div>

      <% if (linkedGrowers && linkedGrowers.length > 0) { %>
        <div class="profile-related">
          <h3>Assigned Rural Grower<%= linkedGrowers.length > 1 ? 's' : '' %></h3>
          <div class="profile-related-list">
            <% linkedGrowers.forEach(function(g) { %>
              <a href="/impact/growers/<%= g.id %>" class="profile-related-item">
                <div class="profile-related-avatar">
                  <img src="<%= g.image_url || '/assets/images/avatar-placeholder.svg' %>" alt="<%= g.name %>">
                </div>
                <div>
                  <strong><%= g.name %></strong>
                  <% if (g.location) { %><span><%= g.location %></span><% } %>
                </div>
              </a>
            <% }); %>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</section>