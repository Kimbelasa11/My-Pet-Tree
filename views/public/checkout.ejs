<section class="page-banner" aria-label="Page header">
  <div class="page-banner-bg" style="background-image: url('<%= hero.image_url || '/assets/images/hero-placeholder.svg' %>');" aria-hidden="true"></div>
  <div class="page-banner-overlay" aria-hidden="true"></div>
  <div class="container page-banner-content">
    <h1 class="page-banner-title"><%= hero.title || 'Complete Your Sponsorship' %></h1>
    <p class="page-banner-subtitle"><%= hero.subtitle || 'Review your sponsorship and support reforestation.' %></p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="checkout-layout">
      <div class="checkout-summary reveal fade-left">
        <h2>Sponsorship Summary</h2>
        <div class="checkout-item">
          <span class="checkout-label">Tree Species</span>
          <span class="checkout-value"><%= tree.name %></span>
        </div>
        <div class="checkout-item">
          <span class="checkout-label">Scientific Name</span>
          <span class="checkout-value"><em><%= tree.scientific_name %></em></span>
        </div>
        <div class="checkout-item">
          <span class="checkout-label">Quantity</span>
          <span class="checkout-value"><%= quantity %></span>
        </div>
        <div class="checkout-item">
          <span class="checkout-label">Sponsorship Fee</span>
          <span class="checkout-value">₱<%= unitPrice %> per tree</span>
        </div>
        <div class="checkout-item checkout-total">
          <span class="checkout-label">Total Contribution</span>
          <span class="checkout-value">₱<%= amount %></span>
        </div>
      </div>

      <div class="checkout-form reveal fade-right">
        <h2>Sponsor Details</h2>
        <form action="/sponsor/payment" method="POST">
          <input type="hidden" name="tree_id" value="<%= tree.id %>">
          <input type="hidden" name="quantity" value="<%= quantity %>">
          <input type="hidden" name="amount" value="<%= amount %>">
          <input type="hidden" name="sponsor_name" value="<%= sponsor.name %>">
          <input type="hidden" name="sponsor_email" value="<%= sponsor.email %>">
          <input type="hidden" name="sponsor_phone" value="<%= sponsor.phone %>">
          <input type="hidden" name="message" value="<%= sponsor.message %>">
          <input type="hidden" name="is_anonymous" value="<%= sponsor.is_anonymous %>">

          <div class="checkout-details">
            <p><strong>Name:</strong> <%= sponsor.name %></p>
            <p><strong>Email:</strong> <%= sponsor.email %></p>
            <% if (sponsor.phone) { %><p><strong>Phone:</strong> <%= sponsor.phone %></p><% } %>
          </div>

          <div class="payment-simulator">
            <p class="payment-notice">This is a demonstration. No real payment will be processed.</p>
            <button type="submit" class="btn btn-primary btn-full btn-lg">
              Support Reforestation — ₱<%= amount %>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
