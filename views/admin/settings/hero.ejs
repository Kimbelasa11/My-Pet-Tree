<div class="page-header">
  <div class="page-header-left">
    <h2>Hero Section Settings</h2>
    <p>Configure the homepage hero banner</p>
  </div>
</div>

<% if (req.query.saved === '1') { %>
  <div class="alert alert-success" data-no-auto-dismiss>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    Hero section settings saved successfully!
    <button class="alert-close" type="button">&times;</button>
  </div>
<% } %>

<form action="/admin/settings/hero" method="POST" enctype="multipart/form-data" id="hero-settings-form">

  <div class="accordion-section">
    <button type="button" class="accordion-header active" onclick="toggleAccordion(this)">
      <span>Hero Background</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div class="accordion-body open">
      <div class="form-group">
        <label>Background Image</label>
        <div class="upload-zone" id="bgUploadZone">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <p>Click to upload or drag &amp; drop</p>
          <p class="upload-hint">JPEG, PNG, WebP, GIF, SVG &mdash; Max 5MB</p>
        </div>
        <input type="file" id="hero_bg_image" name="hero_bg_image" accept="image/*" style="display:none;">
        <div class="image-preview" id="bgPreview">
          <% if (settings.hero_bg_image) { %>
            <div class="current-image" style="position:relative;display:inline-block;">
              <img src="<%= settings.hero_bg_image %>" alt="Background">
              <button type="button" class="btn btn-danger btn-sm remove-image-btn" data-target="hero_bg_image" style="position:absolute;top:8px;right:8px;z-index:2;">Remove</button>
              <span style="position:absolute;bottom:8px;left:8px;background:rgba(0,0,0,0.65);color:#fff;padding:3px 10px;border-radius:6px;font-size:11px;backdrop-filter:blur(4px);">Current</span>
            </div>
          <% } %>
        </div>
        <input type="hidden" name="remove_hero_bg_image" id="remove_hero_bg_image" value="0">
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="hero_overlay_color">Overlay Color</label>
          <div class="color-picker-group">
            <input type="color" id="hero_overlay_color" name="hero_overlay_color" value="<%= settings.hero_overlay_color || '#0f2606' %>">
            <input type="text" id="hero_overlay_color_hex" value="<%= settings.hero_overlay_color || '#0f2606' %>" readonly>
          </div>
        </div>
        <div class="form-group">
          <label for="hero_overlay_opacity">Overlay Opacity: <span id="opacity_value" class="font-mono font-bold"><%= settings.hero_overlay_opacity || '0.70' %></span></label>
          <div class="range-group">
            <input type="range" id="hero_overlay_opacity" name="hero_overlay_opacity" min="0" max="1" step="0.05" value="<%= settings.hero_overlay_opacity || '0.70' %>">
            <span class="range-value font-mono"><%= settings.hero_overlay_opacity || '0.70' %></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="accordion-section">
    <button type="button" class="accordion-header active" onclick="toggleAccordion(this)">
      <span>Hero Text</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div class="accordion-body open">
      <div class="form-group">
        <label for="hero_title">Hero Title</label>
        <input type="text" id="hero_title" name="hero_title" value="<%= settings.hero_title || 'Plant Trees' %>">
      </div>
      <div class="form-group">
        <label for="hero_highlight_text">Highlight Text</label>
        <input type="text" id="hero_highlight_text" name="hero_highlight_text" value="<%= settings.hero_highlight_text || 'Grow Hope' %>">
        <p class="form-help">This word appears with a colored accent in the title.</p>
      </div>
      <div class="form-group">
        <label for="hero_description">Description</label>
        <textarea id="hero_description" name="hero_description" rows="3"><%= settings.hero_description || '' %></textarea>
      </div>
    </div>
  </div>

  <div class="accordion-section">
    <button type="button" class="accordion-header active" onclick="toggleAccordion(this)">
      <span>Call-to-Action Buttons</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div class="accordion-body open">
      <div class="form-row">
        <div class="form-group">
          <label for="hero_btn_primary_text">Primary Button Text</label>
          <input type="text" id="hero_btn_primary_text" name="hero_btn_primary_text" value="<%= settings.hero_btn_primary_text || 'Sponsor a Tree' %>">
        </div>
        <div class="form-group">
          <label for="hero_btn_primary_url">Primary Button URL</label>
          <input type="text" id="hero_btn_primary_url" name="hero_btn_primary_url" value="<%= settings.hero_btn_primary_url || '/sponsor' %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="hero_btn_secondary_text">Secondary Button Text</label>
          <input type="text" id="hero_btn_secondary_text" name="hero_btn_secondary_text" value="<%= settings.hero_btn_secondary_text || 'How It Works' %>">
        </div>
        <div class="form-group">
          <label for="hero_btn_secondary_url">Secondary Button URL</label>
          <input type="text" id="hero_btn_secondary_url" name="hero_btn_secondary_url" value="<%= settings.hero_btn_secondary_url || '/how-it-works' %>">
        </div>
      </div>
    </div>
  </div>

  <div class="accordion-section">
    <button type="button" class="accordion-header active" onclick="toggleAccordion(this)">
      <span>Foreground Image</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div class="accordion-body open">
      <div class="form-group">
        <div class="upload-zone" id="fgUploadZone">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <p>Click to upload or drag &amp; drop</p>
          <p class="upload-hint">JPEG, PNG, WebP, GIF, SVG &mdash; Max 5MB</p>
        </div>
        <input type="file" id="hero_foreground_image" name="hero_foreground_image" accept="image/*" style="display:none;">
        <div class="image-preview" id="fgPreview">
          <% if (settings.hero_foreground_image) { %>
            <div class="current-image" style="position:relative;display:inline-block;">
              <img src="<%= settings.hero_foreground_image %>" alt="Foreground">
              <button type="button" class="btn btn-danger btn-sm remove-image-btn" data-target="hero_foreground_image" style="position:absolute;top:8px;right:8px;z-index:2;">Remove</button>
              <span style="position:absolute;bottom:8px;left:8px;background:rgba(0,0,0,0.65);color:#fff;padding:3px 10px;border-radius:6px;font-size:11px;backdrop-filter:blur(4px);">Current</span>
            </div>
          <% } %>
        </div>
        <input type="hidden" name="remove_hero_foreground_image" id="remove_hero_foreground_image" value="0">
      </div>
    </div>
  </div>

  <div class="accordion-section">
    <button type="button" class="accordion-header active" onclick="toggleAccordion(this)">
      <span>Statistics</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div class="accordion-body open">
      <div class="form-row">
        <div class="form-group">
          <label for="hero_stat_trees_planted">Trees Planted</label>
          <input type="number" id="hero_stat_trees_planted" name="hero_stat_trees_planted" value="<%= settings.hero_stat_trees_planted || '15000' %>" min="0">
        </div>
        <div class="form-group">
          <label for="hero_stat_sponsors">Sponsors</label>
          <input type="number" id="hero_stat_sponsors" name="hero_stat_sponsors" value="<%= settings.hero_stat_sponsors || '3200' %>" min="0">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="hero_stat_rural_growers">Rural Growers</label>
          <input type="number" id="hero_stat_rural_growers" name="hero_stat_rural_growers" value="<%= settings.hero_stat_rural_growers || '85' %>" min="0">
        </div>
        <div class="form-group">
          <label for="hero_stat_communities">Communities</label>
          <input type="number" id="hero_stat_communities" name="hero_stat_communities" value="<%= settings.hero_stat_communities || '42' %>" min="0">
        </div>
      </div>
    </div>
  </div>

  <div class="flex gap-md" style="position:sticky;bottom:0;padding:16px 0;background:var(--bg);z-index:10;">
    <button type="submit" class="btn btn-primary btn-lg" id="save-hero-btn">Save Changes</button>
    <a href="/admin" class="btn btn-secondary btn-lg">Cancel</a>
  </div>
</form>

<script>
function toggleAccordion(btn) {
  btn.classList.toggle('active');
  var body = btn.nextElementSibling;
  if (body) body.classList.toggle('open');
}

(function() {
  var overlayOpacity = document.getElementById('hero_overlay_opacity');
  var opacityValue = document.getElementById('opacity_value');
  var overlayColor = document.getElementById('hero_overlay_color');
  var overlayColorHex = document.getElementById('hero_overlay_color_hex');

  if (overlayOpacity && opacityValue) {
    overlayOpacity.addEventListener('input', function() {
      opacityValue.textContent = parseFloat(this.value).toFixed(2);
    });
  }
  if (overlayColor && overlayColorHex) {
    overlayColor.addEventListener('input', function() {
      overlayColorHex.value = this.value;
    });
  }

  function setupUpload(zoneId, inputId, previewId, hiddenId) {
    var zone = document.getElementById(zoneId);
    var input = document.getElementById(inputId);
    var preview = document.getElementById(previewId);
    var hidden = document.getElementById(hiddenId);
    if (!zone || !input) return;

    zone.addEventListener('click', function() { input.click(); });
    zone.addEventListener('dragover', function(e) { e.preventDefault(); zone.classList.add('dragover'); });
    zone.addEventListener('dragleave', function() { zone.classList.remove('dragover'); });
    zone.addEventListener('drop', function(e) {
      e.preventDefault(); zone.classList.remove('dragover');
      if (e.dataTransfer.files.length) { input.files = e.dataTransfer.files; showPreview(e.dataTransfer.files[0], preview); if (hidden) hidden.value = '0'; }
    });
    input.addEventListener('change', function() { if (this.files.length) showPreview(this.files[0], preview); if (hidden) hidden.value = '0'; });
  }

  function showPreview(file, container) {
    var reader = new FileReader();
    reader.onload = function(e) {
      container.innerHTML = '<div style="position:relative;display:inline-block;">' +
        '<img src="' + e.target.result + '" style="max-width:300px;max-height:180px;border-radius:8px;border:1px solid var(--border);margin-top:12px;">' +
        '<span style="position:absolute;bottom:8px;left:8px;background:rgba(26,110,58,0.85);color:#fff;padding:3px 10px;border-radius:6px;font-size:11px;backdrop-filter:blur(4px);">New</span></div>';
    };
    reader.readAsDataURL(file);
  }

  setupUpload('bgUploadZone', 'hero_bg_image', 'bgPreview', 'remove_hero_bg_image');
  setupUpload('fgUploadZone', 'hero_foreground_image', 'fgPreview', 'remove_hero_foreground_image');

  document.querySelectorAll('.remove-image-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var target = this.getAttribute('data-target');
      var hidden = document.getElementById('remove_' + target);
      var preview = target === 'hero_bg_image' ? document.getElementById('bgPreview') : document.getElementById('fgPreview');
      if (hidden) hidden.value = '1';
      preview.innerHTML = '';
      this.closest('.current-image').remove();
    });
  });

  document.getElementById('hero-settings-form').addEventListener('submit', function() {
    var btn = document.getElementById('save-hero-btn');
    btn.disabled = true;
    btn.classList.add('btn-loading');
    btn.innerHTML = '<span class="btn-spinner"></span> Saving...';
  });
})();
</script>