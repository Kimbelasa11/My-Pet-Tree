<div class="page-header">
  <h2>Hero Section Settings</h2>
</div>

<% if (req.query.saved === '1') { %>
  <div class="alert alert-success">
    <svg class="alert-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    Hero section settings saved successfully!
    <button class="alert-close" type="button">&times;</button>
  </div>
<% } %>

<form action="/admin/settings/hero" method="POST" enctype="multipart/form-data" class="admin-form">
  <div class="admin-form-card" style="max-width:900px;">
    <h2>Hero Background</h2>

    <div class="form-group">
      <label>Hero Background Image</label>
      <div class="upload-zone" id="bgUploadZone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        <p>Click to upload or drag &amp; drop</p>
        <p style="font-size:11px;color:var(--color-text-muted);margin-top:4px;">JPEG, PNG, WebP, GIF, SVG — Max 5MB</p>
      </div>
      <input type="file" id="hero_bg_image" name="hero_bg_image" accept="image/*" style="display:none;">
      <div class="image-preview" id="bgPreview">
        <% if (settings.hero_bg_image) { %>
          <div class="current-image" style="position:relative;display:inline-block;">
            <img src="<%= settings.hero_bg_image %>" alt="Background image" style="max-width:100%;max-height:200px;border-radius:12px;border:1px solid var(--color-border);margin-top:12px;">
            <span style="position:absolute;bottom:16px;left:12px;background:rgba(0,0,0,0.6);color:#fff;padding:4px 12px;border-radius:6px;font-size:12px;backdrop-filter:blur(4px);">Current Image</span>
            <button type="button" class="admin-btn admin-btn-danger admin-btn-sm remove-image-btn" data-target="hero_bg_image" style="position:absolute;top:16px;right:12px;z-index:2;">Remove</button>
          </div>
        <% } %>
      </div>
      <input type="hidden" name="remove_hero_bg_image" id="remove_hero_bg_image" value="0">
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="hero_overlay_color">Background Overlay Color</label>
        <div style="display:flex;gap:10px;align-items:center;">
          <input type="color" id="hero_overlay_color" name="hero_overlay_color" value="<%= settings.hero_overlay_color || '#0f2606' %>" style="width:48px;height:40px;padding:2px;cursor:pointer;">
          <input type="text" id="hero_overlay_color_hex" value="<%= settings.hero_overlay_color || '#0f2606' %>" style="width:100px;font-family:monospace;" readonly>
        </div>
      </div>
      <div class="form-group">
        <label for="hero_overlay_opacity">Overlay Opacity: <span id="opacity_value"><%= settings.hero_overlay_opacity || '0.70' %></span></label>
        <input type="range" id="hero_overlay_opacity" name="hero_overlay_opacity" min="0" max="1" step="0.05" value="<%= settings.hero_overlay_opacity || '0.70' %>" style="width:100%;">
      </div>
    </div>
  </div>

  <div class="admin-form-card" style="max-width:900px;margin-top:20px;">
    <h2>Hero Text Content</h2>

    <div class="form-group">
      <label for="hero_title">Hero Title</label>
      <input type="text" id="hero_title" name="hero_title" value="<%= settings.hero_title || 'Plant Trees' %>">
    </div>

    <div class="form-group">
      <label for="hero_highlight_text">Highlight Text (accent word)</label>
      <input type="text" id="hero_highlight_text" name="hero_highlight_text" value="<%= settings.hero_highlight_text || 'Grow Hope' %>">
      <div class="form-help">This word appears with a green gradient accent in the title.</div>
    </div>

    <div class="form-group">
      <label for="hero_description">Hero Description</label>
      <textarea id="hero_description" name="hero_description" rows="4"><%= settings.hero_description || 'Join the reforestation movement. Sponsor a tree and help restore our planet\'s forests for generations to come.' %></textarea>
    </div>
  </div>

  <div class="admin-form-card" style="max-width:900px;margin-top:20px;">
    <h2>Call-to-Action Buttons</h2>

    <div class="form-row">
      <div class="form-group">
        <label for="hero_btn_primary_text">Primary Button Text</label>
        <input type="text" id="hero_btn_primary_text" name="hero_btn_primary_text" value="<%= settings.hero_btn_primary_text || 'Sponsor a Tree' %>">
      </div>
      <div class="form-group">
        <label for="hero_btn_primary_url">Primary Button URL</label>
        <input type="text" id="hero_btn_primary_url" name="hero_btn_primary_url" value="<%= settings.hero_btn_primary_url || '/sponsor' %>">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="hero_btn_secondary_text">Secondary Button Text</label>
        <input type="text" id="hero_btn_secondary_text" name="hero_btn_secondary_text" value="<%= settings.hero_btn_secondary_text || 'How It Works' %>">
      </div>
      <div class="form-group">
        <label for="hero_btn_secondary_url">Secondary Button URL</label>
        <input type="text" id="hero_btn_secondary_url" name="hero_btn_secondary_url" value="<%= settings.hero_btn_secondary_url || '/how-it-works' %>">
      </div>
    </div>
  </div>

  <div class="admin-form-card" style="max-width:900px;margin-top:20px;">
    <h2>Hero Foreground Image (Tree Seedling)</h2>

    <div class="form-group">
      <label>Foreground Image</label>
      <div class="upload-zone" id="fgUploadZone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        <p>Click to upload or drag &amp; drop</p>
        <p style="font-size:11px;color:var(--color-text-muted);margin-top:4px;">JPEG, PNG, WebP, GIF, SVG — Max 5MB</p>
      </div>
      <input type="file" id="hero_foreground_image" name="hero_foreground_image" accept="image/*" style="display:none;">
      <div class="image-preview" id="fgPreview">
        <% if (settings.hero_foreground_image) { %>
          <div class="current-image" style="position:relative;display:inline-block;">
            <img src="<%= settings.hero_foreground_image %>" alt="Foreground image" style="max-width:100%;max-height:200px;border-radius:12px;border:1px solid var(--color-border);margin-top:12px;">
            <span style="position:absolute;bottom:16px;left:12px;background:rgba(0,0,0,0.6);color:#fff;padding:4px 12px;border-radius:6px;font-size:12px;backdrop-filter:blur(4px);">Current Image</span>
            <button type="button" class="admin-btn admin-btn-danger admin-btn-sm remove-image-btn" data-target="hero_foreground_image" style="position:absolute;top:16px;right:12px;z-index:2;">Remove</button>
          </div>
        <% } %>
      </div>
      <input type="hidden" name="remove_hero_foreground_image" id="remove_hero_foreground_image" value="0">
    </div>
  </div>

  <div class="admin-form-card" style="max-width:900px;margin-top:20px;">
    <h2>Hero Statistics</h2>

    <div class="form-row">
      <div class="form-group">
        <label for="hero_stat_trees_planted">Trees Planted</label>
        <input type="number" id="hero_stat_trees_planted" name="hero_stat_trees_planted" value="<%= settings.hero_stat_trees_planted || '15000' %>" min="0">
      </div>
      <div class="form-group">
        <label for="hero_stat_sponsors">Sponsors</label>
        <input type="number" id="hero_stat_sponsors" name="hero_stat_sponsors" value="<%= settings.hero_stat_sponsors || '3200' %>" min="0">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="hero_stat_rural_growers">Rural Growers</label>
        <input type="number" id="hero_stat_rural_growers" name="hero_stat_rural_growers" value="<%= settings.hero_stat_rural_growers || '85' %>" min="0">
      </div>
      <div class="form-group">
        <label for="hero_stat_communities">Communities Impacted</label>
        <input type="number" id="hero_stat_communities" name="hero_stat_communities" value="<%= settings.hero_stat_communities || '42' %>" min="0">
      </div>
    </div>
  </div>

  <div class="form-actions" style="max-width:900px;">
    <button type="submit" class="admin-btn admin-btn-primary">Save Changes</button>
    <a href="/admin" class="admin-btn admin-btn-secondary">Cancel</a>
  </div>
</form>

<script>
(function() {
  var overlayOpacity = document.getElementById('hero_overlay_opacity');
  var opacityValue = document.getElementById('opacity_value');
  var overlayColor = document.getElementById('hero_overlay_color');
  var overlayColorHex = document.getElementById('hero_overlay_color_hex');

  if (overlayOpacity && opacityValue) {
    overlayOpacity.addEventListener('input', function() {
      opacityValue.textContent = parseFloat(this.value).toFixed(2);
    });
  }
  if (overlayColor && overlayColorHex) {
    overlayColor.addEventListener('input', function() {
      overlayColorHex.value = this.value;
    });
  }

  function setupUpload(zoneId, inputId, previewId, hiddenId) {
    var zone = document.getElementById(zoneId);
    var input = document.getElementById(inputId);
    var preview = document.getElementById(previewId);
    var hidden = document.getElementById(hiddenId);
    if (!zone || !input) return;

    zone.addEventListener('click', function() { input.click(); });
    zone.addEventListener('dragover', function(e) { e.preventDefault(); this.style.borderColor = '#1e3a0e'; this.style.background = '#e8f0e0'; });
    zone.addEventListener('dragleave', function() { this.style.borderColor = ''; this.style.background = ''; });
    zone.addEventListener('drop', function(e) {
      e.preventDefault(); this.style.borderColor = ''; this.style.background = '';
      if (e.dataTransfer.files.length) { input.files = e.dataTransfer.files; showPreview(e.dataTransfer.files[0], preview); }
    });
    input.addEventListener('change', function() { if (this.files.length) showPreview(this.files[0], preview); if (hidden) hidden.value = '0'; });
  }

  function showPreview(file, container) {
    var reader = new FileReader();
    reader.onload = function(e) {
      container.innerHTML = '<div style="position:relative;display:inline-block;">' +
        '<img src="' + e.target.result + '" style="max-width:100%;max-height:200px;border-radius:12px;border:1px solid var(--color-border);margin-top:12px;">' +
        '<span style="position:absolute;bottom:16px;left:12px;background:rgba(45,80,22,0.85);color:#fff;padding:4px 12px;border-radius:6px;font-size:12px;backdrop-filter:blur(4px);">New Image</span></div>';
    };
    reader.readAsDataURL(file);
  }

  setupUpload('bgUploadZone', 'hero_bg_image', 'bgPreview', 'remove_hero_bg_image');
  setupUpload('fgUploadZone', 'hero_foreground_image', 'fgPreview', 'remove_hero_foreground_image');

  document.querySelectorAll('.remove-image-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var target = this.getAttribute('data-target');
      var hidden = document.getElementById('remove_' + target);
      var preview = target === 'hero_bg_image' ? document.getElementById('bgPreview') : document.getElementById('fgPreview');
      if (hidden) hidden.value = '1';
      preview.innerHTML = '';
      this.closest('.current-image').remove();
    });
  });
})();
</script>
