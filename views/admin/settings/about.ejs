<div class="page-header">
  <div class="page-header-left">
    <h2>About Page Settings</h2>
    <p>Configure the public About page content</p>
  </div>
</div>

<% if (req.query.saved === '1') { %>
  <div class="alert alert-success">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    About page settings saved successfully!
    <button class="alert-close" type="button">&times;</button>
  </div>
<% } %>

<form action="/admin/settings/about" method="POST" enctype="multipart/form-data">

  <div class="section-card" style="max-width:900px;">
    <div class="section-card-header">
      <h3>Page Banner</h3>
    </div>
    <div class="section-card-body">
      <div class="form-group">
        <label>Background Image</label>
        <div class="upload-zone" id="bgUploadZone">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <p>Click to upload or drag &amp; drop</p>
          <p class="upload-hint">JPEG, PNG, WebP, GIF, SVG &mdash; Max 5MB</p>
        </div>
        <input type="file" id="about_hero_bg_image" name="about_hero_bg_image" accept="image/*" style="display:none;">
        <div class="image-preview" id="bgPreview">
          <% if (settings.about_hero_bg_image) { %>
            <div class="current-image" style="position:relative;display:inline-block;">
              <img src="<%= settings.about_hero_bg_image %>" alt="Banner Background" style="max-width:300px;max-height:180px;border-radius:8px;border:1px solid var(--border);margin-top:12px;">
              <span style="position:absolute;bottom:12px;left:8px;background:rgba(0,0,0,0.6);color:#fff;padding:3px 10px;border-radius:6px;font-size:11px;">Current</span>
              <button type="button" class="btn btn-danger btn-sm remove-image-btn" data-target="about_hero_bg_image" style="position:absolute;top:16px;right:8px;z-index:2;">Remove</button>
            </div>
          <% } %>
        </div>
        <input type="hidden" name="remove_about_hero_bg_image" id="remove_about_hero_bg_image" value="0">
      </div>

      <div class="form-group">
        <label for="about_hero_title">Banner Title</label>
        <input type="text" id="about_hero_title" name="about_hero_title" value="<%= settings.about_hero_title || 'About My Pet Tree' %>">
      </div>
      <div class="form-group">
        <label for="about_hero_subtitle">Banner Subtitle</label>
        <input type="text" id="about_hero_subtitle" name="about_hero_subtitle" value="<%= settings.about_hero_subtitle || 'A reforestation advocacy platform connecting people who care about the planet.' %>">
      </div>
    </div>
  </div>

  <div class="section-card mt-md" style="max-width:900px;">
    <div class="section-card-header">
      <h3>Story Section</h3>
    </div>
    <div class="section-card-body">
      <div class="form-group">
        <label for="about_story_title">Story Title</label>
        <input type="text" id="about_story_title" name="about_story_title" value="<%= settings.about_story_title || 'Our Story' %>">
      </div>
      <div class="form-group">
        <label for="about_story_body">Story Content</label>
        <textarea id="about_story_body" name="about_story_body" rows="6"><%= settings.about_story_body || 'My Pet Tree began as a small community initiative to restore local forests. Today, we are a growing platform that connects sponsors, urban planters, and rural growers in a shared mission to reforest the planet. Every tree sponsored through our platform represents a partnership between someone who wants to make a difference and a grower who nurtures that tree to maturity.' %></textarea>
      </div>
    </div>
  </div>

  <div class="section-card mt-md" style="max-width:900px;">
    <div class="section-card-header">
      <h3>Values Section</h3>
    </div>
    <div class="section-card-body">
      <div class="form-group">
        <label for="about_values">Values (JSON)</label>
        <textarea id="about_values" name="about_values" rows="10" style="font-family:var(--font-mono);font-size:13px;"><%= settings.about_values || '[{"title":"Sustainability","description":"We prioritize long-term ecological health in every planting."},{"title":"Community","description":"We empower local growers and strengthen rural economies."},{"title":"Transparency","description":"Every tree is tracked, every contribution is accounted for."},{"title":"Impact","description":"We measure success by forests restored and lives improved."}]' %></textarea>
        <p class="form-help" style="margin-top:8px;">Enter values as a JSON array of objects with <code>title</code> and <code>description</code> fields. Each object represents one value card displayed on the About page.</p>
      </div>
    </div>
  </div>

  <div class="flex gap-sm mt-lg" style="max-width:900px;">
    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a href="/admin" class="btn btn-secondary">Cancel</a>
  </div>
</form>

<script>
(function() {
  function setupUpload(zoneId, inputId, previewId, hiddenId) {
    var zone = document.getElementById(zoneId);
    var input = document.getElementById(inputId);
    var preview = document.getElementById(previewId);
    var hidden = document.getElementById(hiddenId);
    if (!zone || !input) return;

    zone.addEventListener('click', function() { input.click(); });
    zone.addEventListener('dragover', function(e) { e.preventDefault(); this.style.borderColor = '#1e3a0e'; this.style.background = '#e8f0e0'; });
    zone.addEventListener('dragleave', function() { this.style.borderColor = ''; this.style.background = ''; });
    zone.addEventListener('drop', function(e) {
      e.preventDefault(); this.style.borderColor = ''; this.style.background = '';
      if (e.dataTransfer.files.length) { input.files = e.dataTransfer.files; showPreview(e.dataTransfer.files[0], preview); }
    });
    input.addEventListener('change', function() { if (this.files.length) showPreview(this.files[0], preview); if (hidden) hidden.value = '0'; });
  }

  function showPreview(file, container) {
    var reader = new FileReader();
    reader.onload = function(e) {
      container.innerHTML = '<div style="position:relative;display:inline-block;">' +
        '<img src="' + e.target.result + '" style="max-width:300px;max-height:180px;border-radius:8px;border:1px solid var(--border);margin-top:12px;">' +
        '<span style="position:absolute;bottom:12px;left:8px;background:rgba(30,58,14,0.85);color:#fff;padding:3px 10px;border-radius:6px;font-size:11px;">New</span></div>';
    };
    reader.readAsDataURL(file);
  }

  setupUpload('bgUploadZone', 'about_hero_bg_image', 'bgPreview', 'remove_about_hero_bg_image');

  document.querySelectorAll('.remove-image-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var target = this.getAttribute('data-target');
      var hidden = document.getElementById('remove_' + target);
      var preview = document.getElementById('bgPreview');
      if (hidden) hidden.value = '1';
      preview.innerHTML = '';
      this.closest('.current-image').remove();
    });
  });
})();
</script>