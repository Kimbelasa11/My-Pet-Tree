<div class="dashboard-welcome">
  <div>
    <h2>Good <%= new Date().getHours() < 12 ? 'morning' : new Date().getHours() < 18 ? 'afternoon' : 'evening' %>, <%= typeof user !== 'undefined' ? user.username : 'Admin' %></h2>
    <p>Here's what's happening across your reforestation platform.</p>
  </div>
  <div class="dashboard-welcome-stats">
    <div class="dashboard-welcome-stat">
      <div class="value">&#8369;<%= stats.totalRaised.toLocaleString() %></div>
      <div class="label">Total Raised</div>
    </div>
    <div class="dashboard-welcome-stat">
      <div class="value" style="color:var(--accent)"><%= stats.sponsorships %></div>
      <div class="label">Sponsorships</div>
    </div>
  </div>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-card-icon icon-green">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
    </div>
    <div class="stat-card-value" data-animate="<%= stats.treeSpecies %>"><%= stats.treeSpecies %></div>
    <div class="stat-card-label">Tree Species</div>
  </div>

  <div class="stat-card">
    <div class="stat-card-icon icon-gold">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg>
    </div>
    <div class="stat-card-value" data-animate="<%= stats.urbanPlanters %>"><%= stats.urbanPlanters %></div>
    <div class="stat-card-label">Urban Planters</div>
  </div>

  <div class="stat-card">
    <div class="stat-card-icon icon-green">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-4-3-4-7c0-2.2 1.8-4 4-4s4 1.8 4 4c0 4-4 7-4 7z"/><path d="M9 3h6l-1 4H10z"/></svg>
    </div>
    <div class="stat-card-value" data-animate="<%= stats.ruralGrowers %>"><%= stats.ruralGrowers %></div>
    <div class="stat-card-label">Rural Growers</div>
  </div>

  <div class="stat-card">
    <div class="stat-card-icon icon-blue">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
    </div>
    <div class="stat-card-value" data-animate="<%= stats.sponsorships %>"><%= stats.sponsorships %></div>
    <div class="stat-card-label">Sponsorships</div>
  </div>

  <div class="stat-card">
    <div class="stat-card-icon icon-gold">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
    </div>
    <div class="stat-card-value">&#8369;<%= stats.totalRaised.toLocaleString() %></div>
    <div class="stat-card-label">Total Raised</div>
  </div>

  <div class="stat-card">
    <div class="stat-card-icon icon-red">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
    </div>
    <div class="stat-card-value" data-animate="<%= stats.unreadMessages %>"><%= stats.unreadMessages %></div>
    <div class="stat-card-label">Unread Messages</div>
  </div>

  <div class="stat-card">
    <div class="stat-card-icon icon-blue">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
    </div>
    <div class="stat-card-value" data-animate="<%= stats.publishedNews %>"><%= stats.publishedNews %></div>
    <div class="stat-card-label">Published News</div>
  </div>

  <div class="stat-card">
    <div class="stat-card-icon icon-green">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    </div>
    <div class="stat-card-value" data-animate="<%= stats.faqs %>"><%= stats.faqs %></div>
    <div class="stat-card-label">FAQs</div>
  </div>
</div>

<div class="section-card mb-lg">
  <div class="section-card-header">
    <h3>Quick Actions</h3>
  </div>
  <div class="section-card-body">
    <div class="quick-actions">
      <a href="/admin/trees" class="quick-action-card">
        <div class="quick-action-icon icon-green">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </div>
        <div class="quick-action-text">
          <h4>Tree Species</h4>
          <p>Manage tree catalog</p>
        </div>
      </a>
      <a href="/admin/urban-planters" class="quick-action-card">
        <div class="quick-action-icon icon-gold">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg>
        </div>
        <div class="quick-action-text">
          <h4>Urban Planters</h4>
          <p>Add planter profiles</p>
        </div>
      </a>
      <a href="/admin/rural-growers" class="quick-action-card">
        <div class="quick-action-icon icon-green">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s-4-3-4-7c0-2.2 1.8-4 4-4s4 1.8 4 4c0 4-4 7-4 7z"/><path d="M9 3h6l-1 4H10z"/></svg>
        </div>
        <div class="quick-action-text">
          <h4>Rural Growers</h4>
          <p>Add grower profiles</p>
        </div>
      </a>
      <a href="/admin/news" class="quick-action-card">
        <div class="quick-action-icon icon-blue">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
        </div>
        <div class="quick-action-text">
          <h4>News & Stories</h4>
          <p>Publish articles</p>
        </div>
      </a>
      <a href="/admin/faqs" class="quick-action-card">
        <div class="quick-action-icon icon-green">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <div class="quick-action-text">
          <h4>FAQs</h4>
          <p>Manage questions</p>
        </div>
      </a>
    </div>
  </div>
</div>

<div class="section-card">
  <div class="section-card-header">
    <h3>Recent Sponsorships</h3>
    <a href="/admin/payments" class="btn btn-ghost btn-sm">View All</a>
  </div>
  <% if (recentSponsorships && recentSponsorships.length > 0) { %>
    <div style="overflow-x:auto;">
      <table style="width:100%;font-size:var(--text-sm);">
        <thead>
          <tr>
            <th style="text-align:left;padding:14px 24px;color:var(--gray-500);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.6px;font-weight:600;background:var(--gray-50);">ID</th>
            <th style="text-align:left;padding:14px 24px;color:var(--gray-500);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.6px;font-weight:600;background:var(--gray-50);">Sponsor</th>
            <th style="text-align:left;padding:14px 24px;color:var(--gray-500);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.6px;font-weight:600;background:var(--gray-50);">Species</th>
            <th style="text-align:left;padding:14px 24px;color:var(--gray-500);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.6px;font-weight:600;background:var(--gray-50);">Amount</th>
            <th style="text-align:left;padding:14px 24px;color:var(--gray-500);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.6px;font-weight:600;background:var(--gray-50);">Status</th>
            <th style="text-align:left;padding:14px 24px;color:var(--gray-500);font-size:var(--text-xs);text-transform:uppercase;letter-spacing:0.6px;font-weight:600;background:var(--gray-50);">Date</th>
          </tr>
        </thead>
        <tbody>
          <% recentSponsorships.forEach(function(s) { %>
            <tr>
              <td style="padding:12px 24px;color:var(--gray-400);">#<%= s.id %></td>
              <td style="padding:12px 24px;"><%= s.sponsor_name %></td>
              <td style="padding:12px 24px;color:var(--gray-500);"><%= s.tree_species_name || '—' %></td>
              <td style="padding:12px 24px;font-weight:600;">&#8369;<%= s.amount.toLocaleString() %></td>
              <td style="padding:12px 24px;">
                <% if (s.status === 'completed') { %><span class="badge badge-success"><span class="badge-dot green"></span> Completed</span>
                <% } else if (s.status === 'pending') { %><span class="badge badge-warning"><span class="badge-dot yellow"></span> Pending</span>
                <% } else if (s.status === 'failed') { %><span class="badge badge-danger"><span class="badge-dot red"></span> Failed</span>
                <% } else { %><span class="badge badge-neutral"><%= s.status %></span><% } %>
              </td>
              <td style="padding:12px 24px;color:var(--gray-400);"><%= new Date(s.created_at).toLocaleDateString() %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="empty-state" style="padding:48px 0;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
      <h3>No sponsorships yet</h3>
      <p>Sponsorships will appear here once donors start sponsoring trees.</p>
    </div>
  <% } %>
</div>