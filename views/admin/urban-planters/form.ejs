<div class="page-header">
  <h2><%= planter ? 'Edit: ' + planter.name : 'Add Urban Planter' %></h2>
</div>

<form action="<%= planter ? '/admin/urban-planters/edit/' + planter.id : '/admin/urban-planters/create' %>" method="POST" enctype="multipart/form-data" class="admin-form">
  <div class="form-group">
    <label for="name">Name <span class="required">*</span></label>
    <input type="text" id="name" name="name" value="<%= planter?.name || '' %>" required>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= planter?.email || '' %>">
    </div>
    <div class="form-group">
      <label for="phone">Phone</label>
      <input type="tel" id="phone" name="phone" value="<%= planter?.phone || '' %>">
    </div>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label for="location">Location</label>
      <input type="text" id="location" name="location" value="<%= planter?.location || '' %>">
    </div>
    <div class="form-group">
      <label for="organization">Organization</label>
      <input type="text" id="organization" name="organization" value="<%= planter?.organization || '' %>">
    </div>
  </div>
  <div class="form-group">
    <label for="bio">Bio</label>
    <textarea id="bio" name="bio" rows="4"><%= planter?.bio || '' %></textarea>
  </div>
  <div class="form-group">
    <label for="is_active">Status</label>
    <select id="is_active" name="is_active">
      <option value="1" <%= planter && planter.is_active ? 'selected' : '' %>>Active</option>
      <option value="0" <%= planter && !planter.is_active ? 'selected' : '' %>>Inactive</option>
    </select>
  </div>
  <% if (planter?.image_url) { %>
    <div class="form-group">
      <label>Current Image</label>
      <div><img src="<%= planter.image_url %>" style="max-width:200px;border-radius:4px;"></div>
    </div>
  <% } %>
  <div class="form-group">
    <label for="image">Photo</label>
    <input type="file" id="image" name="image" accept="image/*">
    <div class="image-preview"></div>
  </div>
  <div class="form-actions">
    <button type="submit" class="admin-btn admin-btn-primary"><%= planter ? 'Update' : 'Create' %></button>
    <a href="/admin/urban-planters" class="admin-btn admin-btn-secondary">Cancel</a>
  </div>
</form>
