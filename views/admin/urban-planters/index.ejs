<div class="page-header">
  <div class="page-header-left">
    <h2>Urban Planters</h2>
    <p>Manage urban planter profiles</p>
  </div>
  <div class="page-header-actions">
    <span class="record-count" id="planter-count"><%= planters.length %> records</span>
    <button class="btn btn-primary" id="btn-add-planter">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Planter
    </button>
  </div>
</div>

<div class="data-table-wrapper">
  <div class="data-table-header">
    <h3>All Urban Planters</h3>
    <div class="data-table-toolbar">
      <div class="table-search-box">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Search planters..." aria-label="Search table">
        <button class="search-clear" aria-label="Clear search">&times;</button>
      </div>
    </div>
  </div>
  <table id="planters-table" class="display" style="width:100%;">
    <thead>
      <tr>
        <th>Name</th>
        <th>Location</th>
        <th>Organization</th>
        <th>Email</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (planters.length > 0) { %>
        <% planters.forEach(function(p) { %>
          <tr>
            <td><strong><%= p.name %></strong></td>
            <td><%= p.location || '—' %></td>
            <td><%= p.organization || '—' %></td>
            <td class="text-muted"><%= p.email || '—' %></td>
            <td>
              <% if (p.is_active) { %><span class="badge badge-success"><span class="badge-dot green"></span> Active</span>
              <% } else { %><span class="badge badge-neutral">Inactive</span><% } %>
            </td>
            <td>
              <div class="table-row-actions">
                <button class="btn btn-ghost btn-sm btn-edit-planter" data-id="<%= p.id %>" title="Edit">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
                <button class="btn btn-danger-ghost btn-sm btn-delete-planter" data-id="<%= p.id %>" title="Delete">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                </button>
              </div>
            </td>
          </tr>
        <% }); %>
      <% } %>
    </tbody>
  </table>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var table = DataTable.init('#planters-table', {
    order: [[0, 'asc']],
    columnDefs: [{ orderable: false, targets: 5 }],
    language: {
      emptyTable: 'No urban planters found. Click "Add Planter" to get started.'
    }
  });

  var planterCrud = ModalForm.create({
    name: 'planter',
    label: 'Urban Planter',
    apiUrl: '/admin/api/urban-planters',
    tableId: '#planters-table',
    fields: [
      { name: 'name', label: 'Name', required: true },
      { name: 'email', label: 'Email', type: 'email' },
      { name: 'phone', label: 'Phone', type: 'tel' },
      { name: 'location', label: 'Location' },
      { name: 'organization', label: 'Organization' },
      { name: 'bio', label: 'Bio', type: 'textarea', rows: 3 },
      { name: 'image', label: 'Photo', type: 'file', currentImage: true },
      { name: 'is_active', label: 'Status', type: 'select', options: [{ value: '1', label: 'Active' }, { value: '0', label: 'Inactive' }], default: '1' }
    ]
  });

  document.getElementById('btn-add-planter').addEventListener('click', function() { planterCrud.openAdd(); });

  document.addEventListener('click', function(e) {
    var editBtn = e.target.closest('.btn-edit-planter');
    if (editBtn) { planterCrud.openEdit(editBtn.getAttribute('data-id')); }
    var delBtn = e.target.closest('.btn-delete-planter');
    if (delBtn) { planterCrud.handleDelete(delBtn.getAttribute('data-id')); }
  });
});
</script>