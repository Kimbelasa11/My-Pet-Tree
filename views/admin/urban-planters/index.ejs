<div class="page-header">
  <h2>Urban Planters</h2>
  <a href="/admin/urban-planters/create" class="admin-btn admin-btn-primary">Add Planter</a>
</div>

<div class="table-container">
  <table>
    <thead>
      <tr><th>Name</th><th>Email</th><th>Location</th><th>Organization</th><th>Status</th><th>Actions</th></tr>
    </thead>
    <tbody>
      <% if (planters && planters.length > 0) { %>
        <% planters.forEach(function(p) { %>
          <tr>
            <td><strong><%= p.name %></strong></td>
            <td><%= p.email || 'N/A' %></td>
            <td><%= p.location || 'N/A' %></td>
            <td><%= p.organization || 'N/A' %></td>
            <td><span class="badge badge-<%= p.is_active ? 'success' : 'danger' %>"><%= p.is_active ? 'Active' : 'Inactive' %></span></td>
            <td>
              <div class="admin-btn-group">
                <a href="/admin/urban-planters/edit/<%= p.id %>" class="admin-btn admin-btn-secondary admin-btn-sm">Edit</a>
                <form action="/admin/urban-planters/delete/<%= p.id %>" method="POST" style="display:inline;">
                  <button type="submit" class="admin-btn admin-btn-danger admin-btn-sm" data-confirm="Delete this planter?">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% }); %>
      <% } else { %>
        <tr><td colspan="6" class="text-center">No urban planters found.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
