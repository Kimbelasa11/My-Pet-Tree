<div class="page-header">
  <div class="page-header-left">
    <h2>Tree Species</h2>
    <p>Manage the tree catalog available for sponsorship</p>
  </div>
  <div class="page-header-actions">
    <span class="record-count" id="tree-count"><%= trees.length %> records</span>
    <button class="btn btn-primary" id="btn-add-tree">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Species
    </button>
  </div>
</div>

<div class="data-table-wrapper">
  <div class="data-table-header">
    <h3>All Tree Species</h3>
    <div class="data-table-toolbar">
      <div class="table-search-box">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Search species..." aria-label="Search table">
        <button class="search-clear" aria-label="Clear search">&times;</button>
      </div>
    </div>
  </div>
  <table id="trees-table" class="display" style="width:100%;">
    <thead>
      <tr>
        <th>Name</th>
        <th>Scientific Name</th>
        <th>Native Region</th>
        <th>Growth Rate</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (trees.length > 0) { %>
        <% trees.forEach(function(t) { %>
          <tr>
            <td><strong><%= t.name %></strong></td>
            <td class="text-muted"><em><%= t.scientific_name || '—' %></em></td>
            <td><%= t.native_region || '—' %></td>
            <td><%= t.growth_rate || '—' %></td>
            <td>
              <% if (t.is_active) { %><span class="badge badge-success"><span class="badge-dot green"></span> Active</span>
              <% } else { %><span class="badge badge-neutral">Inactive</span><% } %>
            </td>
            <td>
              <div class="table-row-actions">
                <button class="btn btn-ghost btn-sm btn-edit-tree" data-id="<%= t.id %>" title="Edit">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
                <button class="btn btn-danger-ghost btn-sm btn-delete-tree" data-id="<%= t.id %>" title="Delete">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                </button>
              </div>
            </td>
          </tr>
        <% }); %>
      <% } %>
    </tbody>
  </table>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var table = DataTable.init('#trees-table', {
    order: [[0, 'asc']],
    columnDefs: [{ orderable: false, targets: 5 }],
    language: {
      emptyTable: 'No tree species found. Click "Add Species" to get started.'
    }
  });

  var treeCrud = ModalForm.create({
    name: 'tree',
    label: 'Tree Species',
    apiUrl: '/admin/api/trees',
    tableId: '#trees-table',
    fields: [
      { name: 'name', label: 'Name', required: true },
      { name: 'scientific_name', label: 'Scientific Name', placeholder: 'e.g., Narra' },
      { name: 'description', label: 'Description', type: 'textarea', rows: 3 },
      { name: 'benefits', label: 'Benefits', type: 'textarea', rows: 2 },
      { name: 'native_region', label: 'Native Region', placeholder: 'e.g., Southeast Asia' },
      { name: 'growth_rate', label: 'Growth Rate', placeholder: 'e.g., Moderate' },
      { name: 'max_height', label: 'Max Height', placeholder: 'e.g., 30 meters' },
      { name: 'climate_zone', label: 'Climate Zone', placeholder: 'e.g., Tropical' },
      { name: 'image', label: 'Photo', type: 'file', currentImage: true },
      { name: 'is_active', label: 'Status', type: 'select', options: [{ value: '1', label: 'Active' }, { value: '0', label: 'Inactive' }], default: '1' }
    ]
  });

  document.getElementById('btn-add-tree').addEventListener('click', function() { treeCrud.openAdd(); });

  document.addEventListener('click', function(e) {
    var editBtn = e.target.closest('.btn-edit-tree');
    if (editBtn) { treeCrud.openEdit(editBtn.getAttribute('data-id')); }
    var delBtn = e.target.closest('.btn-delete-tree');
    if (delBtn) { treeCrud.handleDelete(delBtn.getAttribute('data-id')); }
  });
});
</script>