<div class="page-header">
  <h2>Tree Species</h2>
  <a href="/admin/trees/create" class="admin-btn admin-btn-primary">Add Species</a>
</div>

<div class="table-container">
  <table>
    <thead>
      <tr><th>Name</th><th>Scientific Name</th><th>Region</th><th>Status</th><th>Actions</th></tr>
    </thead>
    <tbody>
      <% if (trees && trees.length > 0) { %>
        <% trees.forEach(function(t) { %>
          <tr>
            <td><strong><%= t.name %></strong></td>
            <td><em><%= t.scientific_name || 'N/A' %></em></td>
            <td><%= t.native_region || 'N/A' %></td>
            <td><span class="badge badge-<%= t.is_active ? 'success' : 'danger' %>"><%= t.is_active ? 'Active' : 'Inactive' %></span></td>
            <td>
              <div class="admin-btn-group">
                <a href="/admin/trees/edit/<%= t.id %>" class="admin-btn admin-btn-secondary admin-btn-sm">Edit</a>
                <form action="/admin/trees/delete/<%= t.id %>" method="POST" style="display:inline;">
                  <button type="submit" class="admin-btn admin-btn-danger admin-btn-sm" data-confirm="Delete this species?">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% }); %>
      <% } else { %>
        <tr><td colspan="5" class="text-center">No tree species found.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
