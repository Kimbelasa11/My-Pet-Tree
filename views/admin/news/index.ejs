<div class="page-header">
  <h2>News & Stories</h2>
  <a href="/admin/news/create" class="admin-btn admin-btn-primary">Add Article</a>
</div>

<div class="table-container">
  <table>
    <thead>
      <tr><th>Title</th><th>Author</th><th>Status</th><th>Published</th><th>Actions</th></tr>
    </thead>
    <tbody>
      <% if (articles && articles.length > 0) { %>
        <% articles.forEach(function(a) { %>
          <tr>
            <td><strong><%= a.title %></strong></td>
            <td><%= a.author || 'N/A' %></td>
            <td><span class="badge badge-<%= a.is_published ? 'success' : 'warning' %>"><%= a.is_published ? 'Published' : 'Draft' %></span></td>
            <td><%= a.published_at ? new Date(a.published_at).toLocaleDateString() : '—' %></td>
            <td>
              <div class="admin-btn-group">
                <a href="/admin/news/edit/<%= a.id %>" class="admin-btn admin-btn-secondary admin-btn-sm">Edit</a>
                <form action="/admin/news/delete/<%= a.id %>" method="POST" style="display:inline;">
                  <button type="submit" class="admin-btn admin-btn-danger admin-btn-sm" data-confirm="Delete this article?">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% }); %>
      <% } else { %>
        <tr><td colspan="5" class="text-center">No articles found.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
