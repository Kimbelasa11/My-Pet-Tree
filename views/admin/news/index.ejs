<div class="page-header">
  <div class="page-header-left">
    <h2>News &amp; Stories</h2>
    <p>Manage published articles and blog posts</p>
  </div>
  <div class="page-header-actions">
    <span class="record-count" id="article-count"><%= articles.length %> records</span>
    <button class="btn btn-primary" id="btn-add-article">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Article
    </button>
  </div>
</div>

<div class="data-table-wrapper">
  <div class="data-table-header">
    <h3>All Articles</h3>
    <div class="data-table-toolbar">
      <div class="table-search-box">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Search articles..." aria-label="Search table">
        <button class="search-clear" aria-label="Clear search">&times;</button>
      </div>
    </div>
  </div>
  <table id="news-table" class="display" style="width:100%;">
    <thead>
      <tr>
        <th>Title</th>
        <th>Author</th>
        <th>Status</th>
        <th>Published</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (articles.length > 0) { %>
        <% articles.forEach(function(a) { %>
          <tr>
            <td><strong><%= a.title %></strong></td>
            <td class="text-muted"><%= a.author || '—' %></td>
            <td>
              <% if (a.is_published) { %><span class="badge badge-success"><span class="badge-dot green"></span> Published</span>
              <% } else { %><span class="badge badge-warning"><span class="badge-dot yellow"></span> Draft</span><% } %>
            </td>
            <td class="text-muted"><%= a.published_at ? new Date(a.published_at).toLocaleDateString() : '—' %></td>
            <td>
              <div class="table-row-actions">
                <button class="btn btn-ghost btn-sm btn-edit-article" data-id="<%= a.id %>" title="Edit">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
                <button class="btn btn-danger-ghost btn-sm btn-delete-article" data-id="<%= a.id %>" title="Delete">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                </button>
              </div>
            </td>
          </tr>
        <% }); %>
      <% } %>
    </tbody>
  </table>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var table = DataTable.init('#news-table', {
    order: [[3, 'desc']],
    columnDefs: [
      { orderable: false, targets: 4 },
      { type: 'date', targets: 3 }
    ],
    language: {
      emptyTable: 'No articles found. Click "Add Article" to get started.'
    }
  });

  var newsCrud = ModalForm.create({
    name: 'news',
    label: 'Article',
    apiUrl: '/admin/api/news',
    tableId: '#news-table',
    size: 'lg',
    fields: [
      { name: 'title', label: 'Title', required: true },
      { name: 'excerpt', label: 'Excerpt', type: 'textarea', rows: 2 },
      { name: 'body', label: 'Body', type: 'textarea', rows: 8 },
      { name: 'author', label: 'Author' },
      { name: 'image', label: 'Featured Image', type: 'file', currentImage: true },
      { name: 'is_published', label: 'Status', type: 'select', options: [{ value: '1', label: 'Published' }, { value: '0', label: 'Draft' }], default: '0' }
    ]
  });

  document.getElementById('btn-add-article').addEventListener('click', function() { newsCrud.openAdd(); });

  document.addEventListener('click', function(e) {
    var editBtn = e.target.closest('.btn-edit-article');
    if (editBtn) { newsCrud.openEdit(editBtn.getAttribute('data-id')); }
    var delBtn = e.target.closest('.btn-delete-article');
    if (delBtn) { newsCrud.handleDelete(delBtn.getAttribute('data-id')); }
  });
});
</script>