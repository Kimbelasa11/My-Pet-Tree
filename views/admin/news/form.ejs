<div class="page-header">
  <h2><%= article ? 'Edit: ' + article.title : 'Add News Article' %></h2>
</div>

<form action="<%= article ? '/admin/news/edit/' + article.id : '/admin/news/create' %>" method="POST" enctype="multipart/form-data" class="admin-form">
  <div class="form-group">
    <label for="title">Title <span class="required">*</span></label>
    <input type="text" id="title" name="title" value="<%= article?.title || '' %>" required>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label for="slug">Slug</label>
      <input type="text" id="slug" name="slug" value="<%= article?.slug || '' %>" placeholder="leave blank to auto-generate">
    </div>
    <div class="form-group">
      <label for="author">Author</label>
      <input type="text" id="author" name="author" value="<%= article?.author || '' %>">
    </div>
  </div>
  <div class="form-group">
    <label for="excerpt">Excerpt</label>
    <textarea id="excerpt" name="excerpt" rows="2"><%= article?.excerpt || '' %></textarea>
  </div>
  <div class="form-group">
    <label for="body">Body</label>
    <textarea id="body" name="body" rows="12"><%= article?.body || '' %></textarea>
  </div>
  <div class="form-group">
    <label for="is_published">Status</label>
    <select id="is_published" name="is_published">
      <option value="1" <%= article && article.is_published ? 'selected' : '' %>>Published</option>
      <option value="0" <%= !article || !article.is_published ? 'selected' : '' %>>Draft</option>
    </select>
  </div>
  <% if (article?.image_url) { %>
    <div class="form-group">
      <label>Current Image</label>
      <div><img src="<%= article.image_url %>" style="max-width:200px;border-radius:4px;"></div>
    </div>
  <% } %>
  <div class="form-group">
    <label for="image">Featured Image</label>
    <input type="file" id="image" name="image" accept="image/*">
    <div class="image-preview"></div>
  </div>
  <div class="form-actions">
    <button type="submit" class="admin-btn admin-btn-primary"><%= article ? 'Update' : 'Create' %></button>
    <a href="/admin/news" class="admin-btn admin-btn-secondary">Cancel</a>
  </div>
</form>
