<div class="page-header">
  <h2>FAQs</h2>
  <a href="/admin/faqs/create" class="admin-btn admin-btn-primary">Add FAQ</a>
</div>

<div class="table-container">
  <table>
    <thead>
      <tr><th>Question</th><th>Category</th><th>Order</th><th>Status</th><th>Actions</th></tr>
    </thead>
    <tbody>
      <% if (faqs && faqs.length > 0) { %>
        <% faqs.forEach(function(f) { %>
          <tr>
            <td><%= f.question %></td>
            <td><%= f.category || 'Uncategorized' %></td>
            <td><%= f.sort_order %></td>
            <td><span class="badge badge-<%= f.is_active ? 'success' : 'danger' %>"><%= f.is_active ? 'Active' : 'Inactive' %></span></td>
            <td>
              <div class="admin-btn-group">
                <a href="/admin/faqs/edit/<%= f.id %>" class="admin-btn admin-btn-secondary admin-btn-sm">Edit</a>
                <form action="/admin/faqs/delete/<%= f.id %>" method="POST" style="display:inline;">
                  <button type="submit" class="admin-btn admin-btn-danger admin-btn-sm" data-confirm="Delete this FAQ?">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% }); %>
      <% } else { %>
        <tr><td colspan="5" class="text-center">No FAQs found.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
