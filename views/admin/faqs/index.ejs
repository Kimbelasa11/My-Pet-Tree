<div class="page-header">
  <div class="page-header-left">
    <h2>FAQs</h2>
    <p>Manage frequently asked questions</p>
  </div>
  <div class="page-header-actions">
    <span class="record-count" id="faq-count"><%= faqs.length %> records</span>
    <button class="btn btn-primary" id="btn-add-faq">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add FAQ
    </button>
  </div>
</div>

<div class="data-table-wrapper">
  <div class="data-table-header">
    <h3>All FAQs</h3>
    <div class="data-table-toolbar">
      <div class="table-search-box">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Search FAQs..." aria-label="Search table">
        <button class="search-clear" aria-label="Clear search">&times;</button>
      </div>
    </div>
  </div>
  <table id="faqs-table" class="display" style="width:100%;">
    <thead>
      <tr>
        <th>Question</th>
        <th>Category</th>
        <th>Order</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (faqs.length > 0) { %>
        <% faqs.forEach(function(f) { %>
          <tr>
            <td><strong><%= f.question %></strong></td>
            <td class="text-muted"><%= f.category || '—' %></td>
            <td><%= f.sort_order || 0 %></td>
            <td>
              <% if (f.is_active) { %><span class="badge badge-success"><span class="badge-dot green"></span> Active</span>
              <% } else { %><span class="badge badge-neutral">Inactive</span><% } %>
            </td>
            <td>
              <div class="table-row-actions">
                <button class="btn btn-ghost btn-sm btn-edit-faq" data-id="<%= f.id %>" title="Edit">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
                <button class="btn btn-danger-ghost btn-sm btn-delete-faq" data-id="<%= f.id %>" title="Delete">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                </button>
              </div>
            </td>
          </tr>
        <% }); %>
      <% } %>
    </tbody>
  </table>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var table = DataTable.init('#faqs-table', {
    order: [[2, 'asc']],
    columnDefs: [{ orderable: false, targets: 4 }],
    language: {
      emptyTable: 'No FAQs found. Click "Add FAQ" to get started.'
    }
  });

  var faqCrud = ModalForm.create({
    name: 'faq',
    label: 'FAQ',
    apiUrl: '/admin/api/faqs',
    tableId: '#faqs-table',
    fields: [
      { name: 'question', label: 'Question', required: true },
      { name: 'answer', label: 'Answer', type: 'textarea', rows: 4, required: true },
      { name: 'category', label: 'Category', placeholder: 'e.g., General, Sponsorship, Trees' },
      { name: 'sort_order', label: 'Sort Order', type: 'number', default: '0' },
      { name: 'is_active', label: 'Status', type: 'select', options: [{ value: '1', label: 'Active' }, { value: '0', label: 'Inactive' }], default: '1' }
    ]
  });

  document.getElementById('btn-add-faq').addEventListener('click', function() { faqCrud.openAdd(); });

  document.addEventListener('click', function(e) {
    var editBtn = e.target.closest('.btn-edit-faq');
    if (editBtn) { faqCrud.openEdit(editBtn.getAttribute('data-id')); }
    var delBtn = e.target.closest('.btn-delete-faq');
    if (delBtn) { faqCrud.handleDelete(delBtn.getAttribute('data-id')); }
  });
});
</script>