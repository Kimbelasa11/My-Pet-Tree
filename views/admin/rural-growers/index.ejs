<div class="page-header">
  <div class="page-header-left">
    <h2>Rural Growers</h2>
    <p>Manage rural grower profiles</p>
  </div>
  <div class="page-header-actions">
    <span class="record-count" id="grower-count"><%= growers.length %> records</span>
    <button class="btn btn-primary" id="btn-add-grower">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Grower
    </button>
    <button class="btn btn-secondary btn-icon" id="btn-refresh-growers" title="Refresh">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
    </button>
  </div>
</div>

<table id="growers-table" class="display" style="width:100%;">
  <thead>
    <tr>
      <th>Name</th>
      <th>Location</th>
      <th>Farm Size</th>
      <th>Linked Planter</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% growers.forEach(function(g) { %>
      <tr>
        <td><strong><%= g.name %></strong></td>
        <td><%= g.location || '—' %></td>
        <td><%= g.farm_size || '—' %></td>
        <td class="text-muted"><%= g.linkedPlanter ? g.linkedPlanter.name : '—' %></td>
        <td>
          <% if (g.is_active) { %><span class="badge badge-success"><span class="badge-dot green"></span> Active</span>
          <% } else { %><span class="badge badge-neutral">Inactive</span><% } %>
        </td>
        <td>
          <div class="table-row-actions">
            <button class="btn btn-ghost btn-sm btn-edit-grower" data-id="<%= g.id %>" title="Edit">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </button>
            <button class="btn btn-danger-ghost btn-sm btn-delete-grower" data-id="<%= g.id %>" title="Delete">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
            </button>
          </div>
        </td>
      </tr>
    <% }); %>
  </tbody>
</table>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var table = DataTable.init('#growers-table', {
    order: [[0, 'asc']],
    columnDefs: [{ orderable: false, targets: 5 }]
  });

  var growerCrud = ModalForm.create({
    name: 'grower',
    label: 'Rural Grower',
    apiUrl: '/admin/api/rural-growers',
    tableId: '#growers-table',
    fields: [
      { name: 'name', label: 'Name', required: true },
      { name: 'email', label: 'Email', type: 'email' },
      { name: 'phone', label: 'Phone', type: 'tel' },
      { name: 'location', label: 'Location' },
      { name: 'farm_size', label: 'Farm Size', placeholder: 'e.g., 2.5 hectares' },
      { name: 'bio', label: 'Bio', type: 'textarea', rows: 3 },
      { name: 'urban_planter_id', label: 'Urban Planter', type: 'planter_select' },
      { name: 'image', label: 'Photo', type: 'file', currentImage: true },
      { name: 'is_active', label: 'Status', type: 'select', options: [{ value: '1', label: 'Active' }, { value: '0', label: 'Inactive' }], default: '1' }
    ]
  });

  document.getElementById('btn-add-grower').addEventListener('click', function() { growerCrud.openAdd(); });

  document.addEventListener('click', function(e) {
    var editBtn = e.target.closest('.btn-edit-grower');
    if (editBtn) { growerCrud.openEdit(editBtn.getAttribute('data-id')); }
    var delBtn = e.target.closest('.btn-delete-grower');
    if (delBtn) { growerCrud.handleDelete(delBtn.getAttribute('data-id')); }
  });

  document.getElementById('btn-refresh-growers').addEventListener('click', function() {
    location.reload();
  });
});
</script>