<div class="page-header">
  <h2><%= grower ? 'Edit: ' + grower.name : 'Add Rural Grower' %></h2>
</div>

<form action="<%= grower ? '/admin/rural-growers/edit/' + grower.id : '/admin/rural-growers/create' %>" method="POST" enctype="multipart/form-data" class="admin-form">
  <div class="form-group">
    <label for="name">Name <span class="required">*</span></label>
    <input type="text" id="name" name="name" value="<%= grower?.name || '' %>" required>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= grower?.email || '' %>">
    </div>
    <div class="form-group">
      <label for="phone">Phone</label>
      <input type="tel" id="phone" name="phone" value="<%= grower?.phone || '' %>">
    </div>
  </div>
  <div class="form-row">
    <div class="form-group">
      <label for="location">Location</label>
      <input type="text" id="location" name="location" value="<%= grower?.location || '' %>">
    </div>
    <div class="form-group">
      <label for="farm_size">Farm Size</label>
      <input type="text" id="farm_size" name="farm_size" value="<%= grower?.farm_size || '' %>" placeholder="e.g., 2.5 hectares">
    </div>
  </div>
  <div class="form-group">
    <label for="bio">Bio</label>
    <textarea id="bio" name="bio" rows="4"><%= grower?.bio || '' %></textarea>
  </div>

  <div class="form-group">
    <label for="urban_planter_select">Linked Urban Planters</label>
    <select id="urban_planter_select" name="urban_planter_ids" multiple data-selected='<%= JSON.stringify(linkedPlanterIds || []) %>'></select>
    <p style="font-size:12px;color:#888;margin-top:4px;">Search and select one or more Urban Planters linked to this grower.</p>
  </div>

  <div class="form-group">
    <label for="is_active">Status</label>
    <select id="is_active" name="is_active">
      <option value="1" <%= grower && grower.is_active ? 'selected' : '' %>>Active</option>
      <option value="0" <%= grower && !grower.is_active ? 'selected' : '' %>>Inactive</option>
    </select>
  </div>
  <% if (grower?.image_url) { %>
    <div class="form-group">
      <label>Current Image</label>
      <div><img src="<%= grower.image_url %>" style="max-width:200px;border-radius:4px;"></div>
    </div>
  <% } %>
  <div class="form-group">
    <label for="image">Photo</label>
    <input type="file" id="image" name="image" accept="image/*">
    <div class="image-preview"></div>
  </div>
  <div class="form-actions">
    <button type="submit" class="admin-btn admin-btn-primary"><%= grower ? 'Update' : 'Create' %></button>
    <a href="/admin/rural-growers" class="admin-btn admin-btn-secondary">Cancel</a>
  </div>
</form>
