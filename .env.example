# ============================================================
# My Pet Tree — Environment Configuration (Template)
# ============================================================
# Copy this file to .env and fill in your values.

# Server
PORT=3000
NODE_ENV=development

# Session / JWT
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRES_IN=24h

# Database
DB_PATH=data/mypettree.db

# Admin seed credentials (first-run only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123

# ─── Payment Gateway ──────────────────────────────────────────
# Set to "mock", "paymongo", or "xendit"
PAYMENT_GATEWAY=mock

# PayMongo (https://paymongo.com)
# PAYMONGO_SECRET_KEY=sk_test_xxxxxxxxxxxx
# PAYMONGO_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
# PAYMONGO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Xendit (https://xendit.co)
# XENDIT_SECRET_KEY=xnd_development_xxxxxxxxxxxx
# XENDIT_WEBHOOK_TOKEN=whsec_xxxxxxxxxxxx

# Currency
CURRENCY=PHP
CURRENCY_SYMBOL=₱
